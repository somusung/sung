<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>Mvctest</display-name>
 <filter>
 <filter-name>CharacterEncodingFilter</filter-name>
 <filter-class>sung.dept.filter.CharacterEncodingFilter</filter-class>
 <init-param>
 <param-name>encoding</param-name>
 <param-value>UTF-8</param-value>
 </init-param>
 </filter>
 <!--필터 매핑명을 설정한다.-->
 <filter-mapping>
 <filter-name>CharacterEncodingFilter</filter-name>
 <url-pattern>/*</url-pattern>
 </filter-mapping>
<servlet>
<servlet-name>FrontController</servlet-name>
<servlet-class>sung.dept.frontcontroller.DeptDispatcherServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>FrontController</servlet-name>
<url-pattern>*.so</url-pattern>
</servlet-mapping>  
<welcome-file-list><welcome-file>index.jsp</welcome-file></welcome-file-list>
</web-app>